  "remediation_rules": {
    "_comment": "Product-specific remediation steps. Keys match canonical product names from product_map.",
    "firefox": [
      "Deploy Firefox update via RMM software deployment",
      "Enable Firefox auto-update policy via Group Policy (DisableAppUpdate = 0)",
      "AppData installs (%APPDATA%\\Mozilla) bypass managed update \u2014 redeploy as SYSTEM install"
    ],
    "chrome": [
      "Deploy Chrome update via RMM software deployment",
      "Verify Google Update service is running: services.msc ? gupdate/gupdatem",
      "Enforce update policy via Group Policy: Computer Config ? Google ? Update ? Auto-update",
      "AppData installs (%LOCALAPPDATA%\\Google\\Chrome) bypass managed update \u2014 redeploy as SYSTEM"
    ],
    "edge": [
      "Run: winget upgrade Microsoft.Edge or deploy via RMM",
      "Check Microsoft Edge Update service status in services.msc",
      "For AppData installs (%LOCALAPPDATA%\\Microsoft\\Edge) \u2014 redeploy as managed package"
    ],
    "vlc": [
      "Deploy VLC update via RMM software deployment",
      "VLC has no background updater \u2014 manual or RMM deployment required on each affected device"
    ],
    "ssms": [
      "Download latest SSMS from Microsoft and deploy via RMM",
      "SSMS does not auto-update \u2014 schedule quarterly manual update cycle"
    ]
  },
