# Connect to Exchange Online
Connect-ExchangeOnline -UserPrincipalName a.jones@contoso.com

# ── SHARED MAILBOX ──────────────────────────────────────────────────────────

# Create a new shared mailbox (if it doesn't already exist)
New-Mailbox -Shared -Name "Shared Mailbox Name" -DisplayName "Shared Mailbox Name" -Alias "sharedmailbox" -PrimarySmtpAddress "sharedmailbox@contoso.com"

# Grant a user FullAccess to the shared mailbox (allows opening the mailbox)
Add-MailboxPermission -Identity "sharedmailbox@contoso.com" -User "b.taylor@contoso.com" -AccessRights FullAccess -InheritanceType All -AutoMapping $true

# Grant a user SendAs permission on the shared mailbox (allows sending as the mailbox)
Add-RecipientPermission -Identity "sharedmailbox@contoso.com" -Trustee "b.taylor@contoso.com" -AccessRights SendAs -Confirm:$false

# Grant SendOnBehalf permission on the shared mailbox
Set-Mailbox -Identity "sharedmailbox@contoso.com" -GrantSendOnBehalfTo @{Add="b.taylor@contoso.com"}

# ── REGULAR MAILBOX ─────────────────────────────────────────────────────────

# Grant a user FullAccess to another user's mailbox
Add-MailboxPermission -Identity "j.smith@contoso.com" -User "b.taylor@contoso.com" -AccessRights FullAccess -InheritanceType All -AutoMapping $true

# Grant a user SendAs permission on another user's mailbox
Add-RecipientPermission -Identity "j.smith@contoso.com" -Trustee "b.taylor@contoso.com" -AccessRights SendAs -Confirm:$false

# ── VERIFY ──────────────────────────────────────────────────────────────────

# Confirm FullAccess permissions were applied correctly
Get-MailboxPermission -Identity "sharedmailbox@contoso.com" | Where-Object { $_.AccessRights -eq "FullAccess" -and $_.IsInherited -eq $false }

# Confirm SendAs permissions were applied correctly
Get-RecipientPermission -Identity "sharedmailbox@contoso.com" | Where-Object { $_.AccessRights -eq "SendAs" -and $_.IsInherited -eq $false }

# Disconnect the Exchange Online session when done
Disconnect-ExchangeOnline -Confirm:$false
